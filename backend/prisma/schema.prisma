generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Category {
  id String @default(uuid()) @id 
  name String
  slug String @unique
  image String?

  parentId String? @map("parent_id")
  parent Category? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  ads Ad[]

  

  @@map("categories")
}

model Ad {
  id String @default(uuid()) @id 

  title String
  slug String @unique
  price Int
  discount Int?
  address String
  description String
  images String[]
  views Int @default(0)
  isFinished Boolean @default(false) @map("is_finished")
  condition EAdCondition
  quantity Int? 

  email String
  phone String

  category Category @relation(fields: [categoryId], references: [id], onDelete: NoAction)
  categoryId String @map("category_id")
  characteristics Characteristic[]
  
  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  sellerId String @map("seller_id")

  favorites FavAd[]
  reviews Review[]
  chats Chat[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt() @map("updated_at")
  @@map("ads")
}

model Characteristic {
  id String @default(uuid()) @id 
  name String
  value String

  ad Ad @relation( references: [id], fields: [adId], onDelete: Cascade)
  adId String

  @@map("characteristics")
}

model User {
  id String @default(uuid()) @id 

  name String
  avatar String?
  phone String? @unique
  email String? @unique
  password String? 
  isPhoneVerified Boolean @default(false) @map("is_phone_verified")
  isEmailVerified Boolean @default(false) @map("is_email_verified")
  provider EProviders @default(CREDENTIALS)
  rating Float @default(0.0)

  ads Ad[]
  favorites FavAd[]

  subscribtions Subscription[] @relation(name: "subscribeTo")
  subscribers Subscription[] @relation(name: "subscribeFrom")

  writtenReviews Review[] @relation(name: "writer")
  receiverReviews Review[] @relation(name: "receiver")

  chats ChatUser[]
  messages Message[]

  createdAt DateTime @default(now()) @map("created_at")

@@map("users")
}

model Review {
  id String @default(uuid()) @id 

  isBought String
  howFinished String
  rating Int
  text String

  ad Ad @relation( references: [id], fields: [adId], onDelete: Cascade)
  adId String @map("ad_id")

  writer User @relation(name: "writer", references: [id], fields: [writerId], onDelete: Cascade)
  writerId String @map("writer_id")
  receiver User @relation(name: "receiver", references: [id], fields: [receiverId], onDelete: Cascade)
  receiverId String @map("receiver_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("reviews")

}

model Subscription {
  id String @default(uuid()) @id 

  subscribeTo User @relation(name: "subscribeTo", references: [id], fields: [subscribeToId], onDelete: Cascade) 
  subscribeToId String @map("subscribe_to_id") @unique
  
  subscribeFrom User @relation(name: "subscribeFrom", references: [id], fields: [subscribeFromId], onDelete: Cascade) 
  subscribeFromId String @map("subscribe_from_id")  @unique 

@@map("subscriptions")
}

model Code {
  code String @id @unique
  expiresAt DateTime

  @@map("codes")
}

model FavAd {
  id String @default(uuid()) @id 

   ad Ad @relation( references: [id], fields: [adId], onDelete: Cascade)
  adId String

  user User @relation(references: [id], fields: [userId], onDelete: Cascade)
  userId String

  @@map("favoriteAdItems")
}

model Chat {
  id String @default(uuid()) @id

  participants ChatUser[]

  ad Ad @relation(references: [id], fields: [adId], onDelete: Cascade)
  adId String

  messages Message[]


  createdAt DateTime @default(now()) @map("created_at")

 @@map("chats") 
}

model Message {
  id String @default(uuid()) @id

  text String
  chat Chat @relation(references: [id], fields: [chatId], onDelete: Cascade)
  chatId String

  user User @relation(references: [id], fields: [userId], onDelete: Cascade)
  userId String

  replyTo Message? @relation(name: "replies", references: [id], fields: [replyToId], onDelete: Cascade)
  replyToId String?
  replied Message[] @relation(name: "replies")

  type EMessageType @default(TEXT)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("messages")
}

model ChatUser {
  id String @default(uuid()) @id

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String

  user User @relation(references: [id], fields: [userId], onDelete: Cascade)
  userId String

  @@unique([chatId, userId])
  @@map("chat_users")
}

enum EAdCondition {
  NEW
  USED
}

enum EProviders {
  CREDENTIALS
  GOOGLE
  VK
  YANDEX
}

enum EMessageType {
  TEXT
  VOICE
  IMAGE
}